NETWORK_NAME=Open5GS

MCC=001
MNC=01
TAC=1

INTERNAL_NETWORK_SUBNET=172.22.0.0/24

# Operator Variant Algorithm Configuration Field
OP=""

# MONGODB
MONGO_IP=172.22.0.2

# PCRF
PCRF_IP=172.22.0.4
PCRF_BIND_PORT=3873

# SMF
SMF_IP=172.22.0.7
SMF_DNS1=8.8.8.8
SMF_DNS2=8.8.4.4

# UPF
UPF_IP=172.22.0.8
UPF_ADVERTISE_IP=172.22.0.8
# Allowed values for UPF_TUNTAP_MODE are 'tun' or 'tap'
# If 'tap' is used as IF mode, then UPF_INTERNET_APN_IF_NAME and UPF_IMS_APN_IF_NAME must contain string 'tap'
UPF_TUNTAP_MODE=tun
UPF_INTERNET_APN_IF_NAME=ogstun
UPF_IMS_APN_IF_NAME=ogstun2

# AMF
AMF_IP=172.22.0.10

# AUSF
AUSF_IP=172.22.0.11

# NRF
NRF_IP=172.22.0.12

# UDM
UDM_IP=172.22.0.13

# UDR
UDR_IP=172.22.0.14

# PCSCF
PCSCF_IP=172.22.0.21

# OPEN5GS WEBUI
WEBUI_IP=172.22.0.26

# PCF
PCF_IP=172.22.0.27

# NSSF
NSSF_IP=172.22.0.28

# BSF
BSF_IP=172.22.0.29

# SCP
SCP_IP=172.22.0.35

# OCS
OCS_IP=172.22.0.40
OCS_BIND_PORT=3872

# OSMOEPDG
OSMOEPDG_IP=172.22.0.41

# DNN LIST
DNN_LIST="internet,192.168.100.0/24,ogstun;ims,192.168.101.0/24,ogstun2"

# UE IPv4 Subnet Range for APN=internet
UE_IPV4_INTERNET=192.168.100.0/24

# UE IPv4 Subnet Range for APN=ims
UE_IPV4_IMS=192.168.101.0/24

# Maximum Number of UEs
MAX_NUM_UE=1024

DEPLOYMENT_PREFIX=5g-core-0b1c0beba3ff
COMPOSE_PROJECT_NAME=5g-core-0b1c0beba3ff